{
  "name": "example-express-byo-kysely",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/migrate.ts && tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "migrate": "tsx src/migrate.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "dependencies": {
    "@fossyl/core": "workspace:*",
    "@fossyl/express": "workspace:*",
    "express": "^4.21.0",
    "@fossyl/kysely": "workspace:*",
    "kysely": "^0.27.0",
    "@libsql/client": "^0.14.0",
    "@libsql/kysely-libsql": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-fossyl": "workspace:*",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@types/express": "^4.17.0",
    "better-sqlite3": "^11.0.0"
  }
}
