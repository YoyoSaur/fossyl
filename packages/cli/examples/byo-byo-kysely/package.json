{
  "name": "example-byo-byo-kysely",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "migrate": "tsx src/migrate.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "dependencies": {
    "@fossyl/core": "workspace:*",
    "@fossyl/kysely": "workspace:*",
    "kysely": "^0.27.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-fossyl": "workspace:*",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@types/better-sqlite3": "^7.6.0"
  }
}
