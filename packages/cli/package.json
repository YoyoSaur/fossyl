{
  "name": "fossyl",
  "version": "1.1.1",
  "type": "module",
  "description": "CLI for scaffolding fossyl projects",
  "bin": {
    "fossyl": "./bin/fossyl.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "bin",
    "dist",
    "examples"
  ],
  "scripts": {
    "build": "node scripts/generate-versions.js && tsup src/index.ts --format cjs,esm --dts && cp USAGE.md dist/AGENTS.md && echo 'This project uses AGENTS.md for AI instructions. See [AGENTS.md](./AGENTS.md).' > dist/CLAUDE.md && mkdir -p dist/skills && cp -r ../../skills/* dist/skills/ && cp ../../for-the-devs/agent-source.yaml dist/",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "keywords": [
    "fossyl",
    "cli",
    "scaffolding",
    "rest-api",
    "typescript",
    "generator",
    "project-generator",
    "create-app",
    "starter",
    "boilerplate",
    "api-generator",
    "nodejs",
    "backend"
  ],
  "author": "YoyoSaur",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/YoyoSaur/fossyl.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/YoyoSaur/fossyl#readme",
  "bugs": {
    "url": "https://github.com/YoyoSaur/fossyl/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
